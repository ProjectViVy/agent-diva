{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "paths": {
      "@morediva/shared-avatar-protocol": [
        "../shared-avatar-protocol/src/index.ts"
      ]
    }
  },
  "include": [
    "src/index.ts",
    "src/protocol.ts",
    "src/runtime/**/*.ts"
  ]
}
