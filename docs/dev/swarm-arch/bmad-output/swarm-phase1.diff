+    }
+
+    /// 灏濊瘯鍙戝皠涓€鏉′簨浠讹細鐨眰鍏冲垯涓?no-op锛涘惁鍒欏叆缂撳啿骞舵寜绛栫暐鍙兘绔嬪嵆 flush銆?+    pub fn try_emit(&self, event: ProcessEventV0) {
+        if !self.cortex.snapshot().enabled {
+            return;
+        }
+        let mut guard = self.state.lock().unwrap_or_else(|e| e.into_inner());
+        guard.pending.push(event);
+        let last = guard.pending.last().expect("just pushed");
+        let flush = guard.should_flush_after_push(last);
+        if flush {
+            let batch = guard.drain();
+            drop(guard);
+            if !batch.is_empty() {
+                self.sink.deliver_batch(batch);
+            }
+        }
+    }
+
+    /// 灏嗗綋鍓嶇紦鍐插叏閮ㄤ笅鍙戯紙娴嬭瘯鎴?turn 缁撴潫鏃惰皟鐢紝閬垮厤鎸傝捣鏈揪鏃堕棿绐楃殑 phase 浜嬩欢锛夈€?+    pub fn flush_pending(&self) {
+        if !self.cortex.snapshot().enabled {
+            return;
+        }
+        let batch = {
+            let mut guard = self.state.lock().unwrap_or_else(|e| e.into_inner());
+            guard.drain()
+        };
+        if !batch.is_empty() {
+            self.sink.deliver_batch(batch);
+        }
+    }
+}
