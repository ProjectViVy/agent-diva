+/// 鑺傛祦涓庢壒澶勭悊閰嶇疆銆?+#[derive(Debug, Clone)]
+pub struct ProcessEventThrottleConfig {
+    /// `swarm_phase_changed` 绛夊彲鍚堝苟浜嬩欢鐨勬渶闀跨瓑寰呯獥鍙ｃ€?+    pub flush_interval: Duration,
+    /// 浠讳竴鏃跺埢缂撳啿鍐呮渶澶ф潯鏁帮紱瓒呭嚭鍒欏己鍒?flush銆?+    pub max_batch: usize,
+}
+
+impl Default for ProcessEventThrottleConfig {
