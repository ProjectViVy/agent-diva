+}
+
+/// 鍏堢粡 gateway 鍚屾閽╋紝鍐嶅啓鍏ョ湡鐩告簮锛涘け璐ユ椂涓嶆敼鐘舵€併€佷笉 emit锛圫tory 2.2 / NFR-R1锛夈€?+fn apply_cortex_target_after_sync(
+    state: &Arc<CortexRuntime>,
+    target_enabled: bool,
+    op_label: &'static str,
+) -> Result<CortexState, String> {
+    cortex_sync::sync_cortex_before_commit(target_enabled, op_label)?;
+    state.set_enabled(target_enabled);
+    Ok(state.snapshot())
+}
+
+/// 璁剧疆鐨眰寮€/鍏筹紱鎴愬姛鍚庡箍鎾?`cortex_toggled`锛坧ayload 涓?[`CortexState`]锛屽惈 `schemaVersion`锛夈€?+#[tauri::command]
+pub fn set_cortex_enabled(
+    enabled: bool,
+    app: AppHandle,
+    state: State<'_, Arc<CortexRuntime>>,
+) -> Result<CortexState, String> {
+    let current = state.snapshot();
+    if current.enabled == enabled {
+        return Ok(current);
+    }
+    let snap = apply_cortex_target_after_sync(&state, enabled, "set_cortex_enabled")?;
+    let _ = app.emit("cortex_toggled", &snap);
+    Ok(snap)
+}
