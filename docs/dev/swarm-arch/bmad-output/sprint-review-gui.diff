+/// 鍒囨崲鐨眰寮€/鍏冲苟骞挎挱 `cortex_toggled`銆?+#[tauri::command]
+pub fn toggle_cortex(
+    app: AppHandle,
+    state: State<'_, Arc<CortexRuntime>>,
+) -> Result<CortexState, String> {
+    let before = state.snapshot();
+    let target = !before.enabled;
+    let snap = apply_cortex_target_after_sync(&state, target, "toggle_cortex")?;
+    let _ = app.emit("cortex_toggled", &snap);
+    Ok(snap)
+}
